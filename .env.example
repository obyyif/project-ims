# Environment Variables — project-ims (Frontend)
# Copy this file to .env.local and fill in the values

# API Configuration
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/lms

# WebSocket (Laravel Reverb) Configuration
NEXT_PUBLIC_WS_HOST=localhost
NEXT_PUBLIC_WS_PORT=8080
NEXT_PUBLIC_WS_SCHEME=http

# App
NEXT_PUBLIC_APP_NAME="LMS Melesat"
NEXT_PUBLIC_SCHOOL_NAME="SMKN 1 Garut"
